          "attributes": {
            "base64_encode": true,
            "gzip": true,
            "id": "163314542",
            "part": [
              {
                "content": "---\n\nusers:\n- name: ansible\n  ssh-authorized-keys:\n  - ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAIM6rP3Prnx1LgTpvY7qrJ73ygAPG3Ge38yGXKxDPmAp0 ansible@cloudspc\n\n  sudo: ['ALL=(ALL) NOPASSWD:ALL']\n",
                "content_type": "text/cloud-config",
                "filename": "",
                "merge_type": ""
              },
              {
                "content": "---\n\nwrite_files:\n- content: |\n    DEVICE=eth1\n    BOOTPROTO=dhcp\n    ONBOOT=yes\n    TYPE=Ethernet\n    PEERDNS=no\n    DEFROUTE=no\n  path: /etc/sysconfig/network-scripts/ifcfg-eth1\n  owner: root:root\n  permissions: '0644'\n",
                "content_type": "text/cloud-config",
                "filename": "",
                "merge_type": ""
              },
              {
                "content": "---\n\nruncmd:\n- ifup eth1\n- yum remove -y zabbix-release zabbix-agent\n- /bin/rm -rf /etc/zabbix /etc/systemd/system/zabbix.service\n- /bin/rm -rf /usr/bin/zabbix-conf-linux.cfg /var/log/zabbix\n- userdel -r -f zabbix\n- localectl set-x11-keymap us\n- yum update -y\n",
                "content_type": "text/cloud-config",
                "filename": "",
                "merge_type": ""
              }
            ],
            "rendered": ""
          }
        }
      ]
    },
